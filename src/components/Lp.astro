<script is:inline>
  (function () {
    /* UTM passthrough: merge LP query params onto every Pettable CTA so paid attribution survives the click */
    (function () {
      var search = window.location.search;
      if (!search) return;
      var incoming = new URLSearchParams(search);
      document.querySelectorAll('a.cta, a[href*="/get-started"]').forEach(function (a) {
        var href = a.getAttribute('href'); if (!href) return;
        try {
          var u = new URL(href, window.location.origin);
          incoming.forEach(function (val, key) { u.searchParams.set(key, val); });
          a.setAttribute('href', u.toString());
        } catch (e) {}
      });
    })();

    /* sticky mobile CTA appears once the hero CTA scrolls away */
    var sticky = document.getElementById('plSticky');
    if (sticky) {
      var onScroll = function () { if (window.scrollY > 480) sticky.classList.add('show'); else sticky.classList.remove('show'); };
      window.addEventListener('scroll', onScroll, { passive: true }); onScroll();
    }

    /* reels: muted loop, autoplay only while in view (keeps mobile from fetching all at once) */
    var vids = document.querySelectorAll('.pl-reel video');
    vids.forEach(function (v) { v.muted = true; v.setAttribute('muted', ''); v.playsInline = true; });
    function tryPlay(v) { var p = v.play(); if (p && p.catch) p.catch(function () {}); }
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) { if (e.isIntersecting) tryPlay(e.target); else e.target.pause(); });
      }, { threshold: 0.25 });
      vids.forEach(function (v) { io.observe(v); });
    } else { vids.forEach(tryPlay); }

    /* desktop: click a reel to feature it (scales up via .is-active); mobile stays a swipe carousel */
    var reelEls = document.querySelectorAll('.pl-ugc .pl-reel');
    reelEls.forEach(function (reel) {
      reel.addEventListener('click', function () {
        if (window.matchMedia('(min-width:900px)').matches) {
          reelEls.forEach(function (r) { r.classList.toggle('is-active', r === reel); });
        }
      });
    });

    /* center the lead reel in the mobile carousel on load */
    var rw = document.getElementById('plUgc');
    if (rw && window.matchMedia('(max-width:860px)').matches) {
      var lead = rw.querySelector('.pl-reel.lead');
      if (lead) rw.scrollLeft = lead.offsetLeft - (rw.clientWidth - lead.clientWidth) / 2;
    }
  })();
</script>
