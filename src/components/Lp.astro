  .pl-lightbox-close:hover{background:#fff;}
  .pl-reel::after{content:"";position:absolute;inset:0;pointer-events:none;z-index:2;
    background:linear-gradient(180deg,rgba(8,20,38,.14) 0%,rgba(8,20,38,0) 22%,rgba(4,12,28,0) 70%,rgba(4,12,28,.28) 100%);}
  .pl-mute{position:absolute;top:11px;right:11px;z-index:3;width:26px;height:26px;border-radius:50%;pointer-events:none;
