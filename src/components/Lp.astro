---
/*
 * Shared Pettable ESA-letter UGC landing page.
 * variant: "emotional"  -> Direction A (emotional + social proof; skeptic-turned-believer reviews)
 *          "fees"       -> Direction C (outcome / no-fees; "what you stop paying" savings grid)
 * Everything else (UGC video wall, trust strip, therapists, how-it-works, what's-included, FAQ,
 * footer, sticky CTA) is shared. Real verified content; no fabricated names/quotes/prices.
 */
interface Props { variant: "emotional" | "fees"; }
const { variant } = Astro.props;

const MNT = "/c/keep-your-pet";
const MEDIA = import.meta.env.DEV ? "/media" : `${MNT}/media`;
const CTA = "https://pettable.com/get-started";

// 8 curated, compressed creator clips. reel3 (MacaBoy3 — legitimacy) is the center/lead.
// reels 6-8 are mobile-carousel-only ("extra"); desktop shows the 5-card fan.
const reels = [1, 2, 3, 4, 5, 6, 7, 8];
const muteIcon = `<svg viewBox="0 0 24 24"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3a4.5 4.5 0 0 0-2.5-4v8a4.5 4.5 0 0 0 2.5-4z"/></svg>`;
// Official Trustpilot green star logomark (paired with the "Trustpilot" wordmark)
const tpStar = `<svg viewBox="0 0 96 96" width="17" height="17" aria-hidden="true" style="display:block"><rect width="96" height="96" fill="#00B67A"/><path fill="#fff" d="M48 64.7 62.6 61l6.1 18.8L48 64.7zM81.6 40.4H55.9L48 16.2l-7.9 24.2H14.4l20.8 15-7.9 24.2 20.8-15 12.8-9.2L81.6 40.4z"/></svg>`;
// Press / accreditation logos (real Pettable CDN assets), shown as a greyscale scrolling marquee
const CDN = "https://cdn.prod.website-files.com/5efb22ae1cebe1d23aa0554c/";
const pressLogos = [
  ["67e6d64f7307d0cbf3b19b19_Newsweek.svg", "Newsweek"],
  ["67e6d64f9db49d3a2c56e3d4_thrillist.svg", "Thrillist"],
  ["67e6d90bf4e2a98a09a4a074_ABC%20News.svg", "ABC News"],
  ["67e6d64fd3422c2fe1bbddab_CBS.svg", "CBS"],
  ["67e6d64f5f00ab48fd5aec8d_HIPAA.svg", "HIPAA compliant"],
  ["67f557865e58287fa1dd91cb_bbb-new.png", "BBB accredited"],
  ["67f55786cbc33f0b94d6aaba_consumer-affairs-logo.png", "Consumer Affairs"],
];
---

<div class="pl-root" style="font-family:'Inter',system-ui,sans-serif;color:#183840;background:#fff;-webkit-font-smoothing:antialiased;">

  <!-- HERO -->
  <section class="pl-hero" style="position:relative;padding:clamp(34px,6vw,56px) clamp(20px,5vw,44px) 8px;text-align:center;background:radial-gradient(110% 70% at 50% -8%,#FCEAE0 0%,#FFFBF8 58%);overflow:hidden;">
    <div style="max-width:880px;margin:0 auto;">
      {variant === "emotional" ? (
        <>
          <div style="font-family:'Plus Jakarta Sans';font-size:clamp(11px,2vw,12px);font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#C55841;margin-bottom:16px;">Real ESA letters · Licensed therapists</div>
          <h1 style="font-family:'Plus Jakarta Sans';font-weight:800;letter-spacing:-.035em;font-size:clamp(34px,6.2vw,58px);line-height:1.04;margin:0;color:#183840;text-align:center!important;text-wrap:pretty;">Your pet already helps you. <span style="color:#E87860;">Now make it official.</span></h1>
          <p style="font-size:clamp(16px,2.4vw,19px);line-height:1.6;color:#5C6B6F;max-width:600px;margin:20px auto 0;text-wrap:pretty;">Talk to a therapist licensed in your state and get a real ESA letter, so your pet can stay where they belong. No pet rent, no deposit, no breed rules.</p>
        </>
      ) : (
        <>
          <div style="font-family:'Plus Jakarta Sans';font-size:clamp(11px,2vw,12px);font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#C55841;margin-bottom:16px;">No pet fees · No breed limits</div>
          <h1 style="font-family:'Plus Jakarta Sans';font-weight:800;letter-spacing:-.035em;font-size:clamp(34px,6.2vw,58px);line-height:1.04;margin:0;color:#183840;text-align:center!important;text-wrap:pretty;">Keep your pet. <span style="color:#E87860;">Skip the pet fees.</span></h1>
          <p style="font-size:clamp(16px,2.4vw,19px);line-height:1.6;color:#5C6B6F;max-width:600px;margin:20px auto 0;text-wrap:pretty;">A real ESA letter from a licensed therapist means no pet rent, no deposit, and no breed or size limits. It's protected under the Fair Housing Act.</p>
        </>
      )}
      <div style="margin-top:28px;display:flex;flex-direction:column;align-items:center;gap:16px;">
        <a href={CTA} class="cta" style="display:inline-flex;align-items:center;gap:10px;background:#E87860;color:#fff;font-family:'Plus Jakarta Sans';font-weight:700;font-size:clamp(16px,2.4vw,18px);padding:18px clamp(28px,5vw,42px);border-radius:14px;text-decoration:none;box-shadow:0 12px 30px rgba(232,120,96,.38);">Get My ESA Letter <span style="font-size:19px;">&rarr;</span></a>
        <div style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;justify-content:center;font-family:'Plus Jakarta Sans';font-weight:600;font-size:clamp(12.5px,2vw,14px);color:#7A888B;">
          <img src={`${MEDIA}/trustpilot-stars.svg`} alt="Rated 4.7 out of 5 on Trustpilot" width="76" height="14" style="height:14px;width:auto;display:block;" />
          <span><strong style="color:#183840;">4.7</strong> on Trustpilot</span>
          <span style="color:#CBD3D4;">·</span>
          <span>Letters in 24–48 hrs</span>
          <span style="color:#CBD3D4;">·</span>
          <span>Money-back guarantee</span>
        </div>
      </div>
    </div>

    <!-- UGC VIDEO WALL -->
    <div class="pl-ugc" id="plUgc">
      {reels.map((n) => (
        <figure class={`pl-reel${n === 3 ? " lead is-active" : ""}${n > 5 ? " extra" : ""}`} data-n={n}>
          <video src={`${MEDIA}/reel${n}.mp4`} poster={`${MEDIA}/reel${n}.webp`} muted loop playsinline preload={n === 3 ? "metadata" : "none"} disablepictureinpicture controlslist="nodownload nofullscreen noremoteplayback" aria-label="Clip from a Pettable pet parent"></video>
          <span class="pl-mute" aria-hidden="true" set:html={muteIcon}></span>
        </figure>
      ))}
    </div>
    <div style="padding-bottom:40px;"></div>
  </section>

  <!-- PRESS / ACCREDITATION + VOLUME (first proof under the UGC wall) -->
  <section style="background:#fff;border-top:1px solid rgba(24,56,64,.06);border-bottom:1px solid rgba(24,56,64,.06);padding:30px 0 26px;overflow:hidden;">
    <div style="text-align:center;font-family:'Plus Jakarta Sans';font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:#8A9699;margin:0 clamp(20px,5vw,44px) 20px;text-wrap:balance;">Over <span style="color:#183840;">450,000</span> ESA letters issued · as featured in</div>
    <div class="pl-marquee">
      <div class="pl-marquee-track">
        {[0,1,2].map((set) => (
          <div class="pl-mset" aria-hidden={set > 0 ? "true" : undefined}>
            {pressLogos.map(([file, name]) => (
              <img src={`${CDN}${file}`} alt={set === 0 ? name : ""} loading="lazy" />
            ))}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section style="background:#FBF1EB;border-bottom:1px solid rgba(24,56,64,.06);padding:22px clamp(20px,5vw,44px);">
    <div class="pl-trust" style="max-width:1180px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:28px;flex-wrap:wrap;">
      <div class="pl-tp" style="display:flex;flex-direction:column;gap:7px;">
        <span style="display:inline-flex;align-items:center;gap:7px;font-family:'Plus Jakarta Sans';font-weight:800;font-size:16px;letter-spacing:-.01em;color:#183840;line-height:1;"><span set:html={tpStar}></span>Trustpilot</span>
        <img src={`${MEDIA}/trustpilot-stars.svg`} alt="Rated 4.7 out of 5 on Trustpilot" width="132" height="25" style="height:25px;width:auto;display:block;" />
        <span style="font-family:'Inter';font-size:13px;color:#7A888B;"><strong style="color:#183840;font-weight:700;">4.7</strong> out of 5 · <strong style="color:#183840;font-weight:700;">6,233</strong> reviews</span>
      </div>
      <div class="pl-trustbadges" style="display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:flex-end;">
        <div class="pl-badge"><span style="color:#E87860;">✓</span> Licensed therapists in your state</div>
        <div class="pl-badge"><span style="color:#E87860;">✓</span> Money-back guarantee</div>
        <div class="pl-badge"><span style="color:#E87860;">✓</span> Fair Housing Act compliant</div>
        <div class="pl-badge"><span style="color:#E87860;">✓</span> 100% online</div>
      </div>
    </div>
  </section>

  {variant === "emotional" ? (
    <!-- WRITTEN REVIEWS (real, verified Trustpilot quotes — honest attribution, no fabricated names) -->
    <section style="background:#fff;padding:clamp(56px,8vw,84px) clamp(20px,5vw,44px);">
      <div style="max-width:1180px;margin:0 auto;">
        <div style="font-family:'Plus Jakarta Sans';font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#C55841;margin-bottom:14px;">What customers say</div>
        <h2 class="pl-h2" style="margin:0 0 36px;max-width:640px;">Most people show up skeptical.</h2>
        <div class="pl-grid3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:22px;">
          <div class="pl-rev">
            <div style="color:#00B67A;font-size:15px;letter-spacing:1px;margin-bottom:14px;">★★★★★</div>
            <p style="font-family:'Inter';font-size:15.5px;line-height:1.6;color:#3F4F53;margin:0 0 18px;">"Kya was incredibly thorough and compassionate. My landlord accepted the letter without a single question."</p>
            <div style="font-family:'Plus Jakarta Sans';font-weight:700;font-size:14px;color:#183840;">Verified Trustpilot review</div>
          </div>
          <div class="pl-rev">
            <div style="color:#00B67A;font-size:15px;letter-spacing:1px;margin-bottom:14px;">★★★★★</div>
            <p style="font-family:'Inter';font-size:15.5px;line-height:1.6;color:#3F4F53;margin:0 0 18px;">"The letter came on my therapist's private practice letterhead — not some company template. That's what convinced my property manager."</p>
            <div style="font-family:'Plus Jakarta Sans';font-weight:700;font-size:14px;color:#183840;">Verified Trustpilot review</div>
          </div>
          <div class="pl-rev">
            <div style="color:#00B67A;font-size:15px;letter-spacing:1px;margin-bottom:14px;">★★★★★</div>
            <p style="font-family:'Inter';font-size:15.5px;line-height:1.6;color:#3F4F53;margin:0 0 18px;">"I was a little nervous at first because I wasn't sure if my letter would be accepted by my landlord or not, but I had no problems, and it was accepted almost immediately."</p>
            <div style="font-family:'Plus Jakarta Sans';font-weight:700;font-size:14px;color:#183840;">Isabelle, Utah <span style="font-weight:500;color:#8A9699;">· Verified review</span></div>
          </div>
        </div>
      </div>
    </section>
  ) : (
    <!-- WHAT YOU STOP PAYING (savings grid) -->
    <section style="background:#fff;padding:clamp(56px,8vw,84px) clamp(20px,5vw,44px);">
      <div style="max-width:1180px;margin:0 auto;">
        <div style="font-family:'Plus Jakarta Sans';font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#C55841;margin-bottom:14px;">What you stop paying</div>
        <h2 class="pl-h2" style="margin:0 0 12px;max-width:640px;">A valid ESA isn't a pet, so the pet charges don't apply.</h2>
        <p style="font-family:'Inter';font-size:16px;line-height:1.65;color:#5C6B6F;max-width:560px;margin:0 0 36px;">Under the Fair Housing Act, a landlord generally can't apply pet rules to a valid emotional support animal. For most renters that adds up fast.</p>
        <div class="pl-grid3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:22px;">
          <div class="pl-save">
            <div style="font-family:'Plus Jakarta Sans';font-weight:700;font-size:16px;color:#183840;margin-bottom:16px;">Monthly pet rent</div>
            <div style="display:flex;align-items:baseline;gap:10px;"><span style="font-family:'Plus Jakarta Sans';font-weight:600;font-size:18px;color:#A9938C;text-decoration:line-through;">$25–$60/mo</span></div>
            <div style="font-family:'Plus Jakarta Sans';font-weight:800;font-size:34px;letter-spacing:-.02em;color:#1F7A53;margin-top:6px;">$0</div>
            <div style="font-family:'Inter';font-size:13.5px;color:#7A888B;margin-top:8px;">Up to $720 saved a year.</div>
          </div>
          <div class="pl-save">
            <div style="font-family:'Plus Jakarta Sans';font-weight:700;font-size:16px;color:#183840;margin-bottom:16px;">One-time pet deposit</div>
            <div style="display:flex;align-items:baseline;gap:10px;"><span style="font-family:'Plus Jakarta Sans';font-weight:600;font-size:18px;color:#A9938C;text-decoration:line-through;">$200–$500</span></div>
            <div style="font-family:'Plus Jakarta Sans';font-weight:800;font-size:34px;letter-spacing:-.02em;color:#1F7A53;margin-top:6px;">$0</div>
            <div style="font-family:'Inter';font-size:13.5px;color:#7A888B;margin-top:8px;">No deposit for a valid ESA.</div>
          </div>
          <div class="pl-save">
            <div style="font-family:'Plus Jakarta Sans';font-weight:700;font-size:16px;color:#183840;margin-bottom:16px;">Breed &amp; size limits</div>
            <div style="display:flex;align-items:baseline;gap:10px;"><span style="font-family:'Plus Jakarta Sans';font-weight:600;font-size:18px;color:#A9938C;text-decoration:line-through;">Restricted</span></div>
            <div style="font-family:'Plus Jakarta Sans';font-weight:800;font-size:34px;letter-spacing:-.02em;color:#1F7A53;margin-top:6px;">Exempt</div>
            <div style="font-family:'Inter';font-size:13.5px;color:#7A888B;margin-top:8px;">Breed and weight caps don't apply.</div>
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- OBJECTION BAND -->
  <section style="background:#183840;color:#fff;padding:clamp(60px,8vw,84px) clamp(20px,5vw,44px);position:relative;overflow:hidden;">
    <div style="position:absolute;right:-80px;top:-60px;width:360px;height:360px;border-radius:50%;background:radial-gradient(circle,rgba(232,120,96,.22),transparent 70%);"></div>
    <div class="pl-grid2" style="max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1.15fr 1fr;gap:clamp(36px,5vw,56px);align-items:start;position:relative;">
      <div>
        <div style="font-family:'Plus Jakarta Sans';font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#F0A892;margin-bottom:18px;">The honest question</div>
        <h2 class="pl-h2 pl-h2-light" style="margin:0;">Worried it's a scam, or that your landlord won't accept it?</h2>
        <div style="margin-top:28px;display:flex;flex-direction:column;gap:16px;">
          <div style="border-left:3px solid #E87860;padding-left:16px;font-family:'Inter';font-style:italic;font-size:clamp(15px,2.2vw,16.5px);line-height:1.5;color:rgba(255,255,255,.82);">"I was so skeptical. I'd read all the Reddit horror stories about fake PDFs."</div>
          <div style="border-left:3px solid #E87860;padding-left:16px;font-family:'Inter';font-style:italic;font-size:clamp(15px,2.2vw,16.5px);line-height:1.5;color:rgba(255,255,255,.82);">"I figured it'd be some sketchy site that takes your money and vanishes."</div>
        </div>
      </div>
      <div style="padding-top:6px;">
        <p style="font-family:'Inter';font-size:clamp(15.5px,2.3vw,17px);line-height:1.7;color:rgba(255,255,255,.88);margin:0 0 14px;">Fair. Here's what actually happens. You have a real <strong style="color:#fff;">consultation with a therapist licensed in your state</strong>, not a checkbox quiz. They write the letter on <strong style="color:#fff;">their own practice letterhead</strong>, with their license number, following your state's Fair Housing rules.</p>
        <p style="font-family:'Inter';font-size:clamp(15.5px,2.3vw,17px);line-height:1.7;color:rgba(255,255,255,.88);margin:0 0 26px;">And if your landlord doesn't accept a valid letter, <strong style="color:#fff;">you get your money back.</strong></p>
        <a href="#how" style="display:inline-flex;align-items:center;gap:9px;background:#E87860;color:#fff;font-family:'Plus Jakarta Sans';font-weight:700;font-size:16px;padding:16px 30px;border-radius:13px;text-decoration:none;box-shadow:0 12px 30px rgba(232,120,96,.4);">See how it works <span style="font-size:17px;">&rarr;</span></a>
      </div>
    </div>
  </section>

  <!-- THERAPISTS (real licensed clinicians, real headshots & credentials) -->
  <section id="therapists" style="background:#fff;padding:clamp(56px,8vw,84px) clamp(20px,5vw,44px);">
    <div style="max-width:1180px;margin:0 auto;">
      <div style="font-family:'Plus Jakarta Sans';font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#C55841;margin-bottom:14px;">Who you'll talk to</div>
      <div class="pl-sectionhead" style="display:flex;justify-content:space-between;align-items:flex-end;gap:30px;flex-wrap:wrap;margin-bottom:38px;">
        <h2 class="pl-h2" style="margin:0;max-width:520px;">Licensed therapists, matched to your state.</h2>
        <p style="font-family:'Inter';font-size:16px;line-height:1.65;color:#5C6B6F;max-width:380px;margin:0;">Every letter is written by a clinician licensed where you live, with their name and license number on it. Not a template.</p>
      </div>
      <div class="pl-grid3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:24px;">
        <div class="pl-doc">
          <div class="pl-doc-av"><img src="https://cdn.prod.website-files.com/60cd7ae35efaf14623f555c5/65b2b066e746932638f596a9_Jennifer%20headshot.avif" alt="Jennifer Bronsnick, MSW, LCSW" loading="lazy" /></div>
          <span class="pl-doc-badge"><span style="color:#00B67A;">✓</span> Licensed</span>
          <div class="pl-doc-name">Jennifer Bronsnick</div>
          <div class="pl-doc-cred">MSW, LCSW</div>
          <div class="pl-doc-desc">Anxiety treatment specialist · Heartmath certified</div>
        </div>
        <div class="pl-doc">
          <div class="pl-doc-av"><img src="https://cdn.prod.website-files.com/60cd7ae35efaf14623f555c5/65b2ae17a7c3997cbb3d551e_Emilie%20Kay%20headshot.avif" alt="Emilie Kay, MSW, LCSW" loading="lazy" /></div>
          <span class="pl-doc-badge"><span style="color:#00B67A;">✓</span> Licensed</span>
          <div class="pl-doc-name">Emilie Kay</div>
          <div class="pl-doc-cred">MSW, LCSW</div>
          <div class="pl-doc-desc">8+ years in mental health · CBT &amp; DBT certified</div>
        </div>
        <div class="pl-doc">
          <div class="pl-doc-av"><img src="https://cdn.prod.website-files.com/60cd7ae35efaf14623f555c5/65aed803c6efd911cfb767b2_Beckman%20Photo%202024.avif" alt="Marvy Beckman, LCSW" loading="lazy" /></div>
          <span class="pl-doc-badge"><span style="color:#00B67A;">✓</span> Licensed</span>
          <div class="pl-doc-name">Marvy Beckman</div>
          <div class="pl-doc-cred">LCSW</div>
          <div class="pl-doc-desc">Licensed clinical social worker · Direct line on every letter</div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section id="how" style="background:#FBF1EB;padding:clamp(56px,8vw,84px) clamp(20px,5vw,44px);">
    <div style="max-width:1180px;margin:0 auto;">
      <div style="font-family:'Plus Jakarta Sans';font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#C55841;margin-bottom:36px;">How it works</div>
      <div class="pl-grid3" style="display:grid;grid-template-columns:repeat(3,1fr);gap:clamp(28px,4vw,40px);">
        <div>
          <div class="pl-num">1</div>
          <h3 class="pl-h3">Take the 3-minute intake.</h3>
          <p class="pl-step-p">Tell us about you and your pet. Completely online, nothing charged to start.</p>
        </div>
        <div>
          <div class="pl-num">2</div>
          <h3 class="pl-h3">Talk to a licensed therapist.</h3>
          <p class="pl-step-p">A real consultation with a clinician licensed in your state, often the same week.</p>
        </div>
        <div>
          <div class="pl-num">3</div>
          <h3 class="pl-h3">Get your ESA letter.</h3>
          <p class="pl-step-p">Valid for your state, on the therapist's own letterhead. Typically within 24–48 hours, money-back guaranteed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED (no explicit price — Pettable pricing-transparency rule) -->
  <section id="start" style="background:#fff;padding:clamp(56px,8vw,84px) clamp(20px,5vw,44px);">
    <div class="pl-grid2" style="max-width:1180px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:clamp(36px,5vw,56px);align-items:center;">
      <div>
        <div style="font-family:'Plus Jakarta Sans';font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#C55841;margin-bottom:14px;">What you actually get</div>
        <h2 class="pl-h2" style="margin:0 0 22px;">No surprise charges.</h2>
        <div style="display:flex;flex-direction:column;gap:14px;">
          <div class="pl-inc"><span class="pl-inc-c">✓</span><span>A live consultation with a therapist licensed in your state</span></div>
          <div class="pl-inc"><span class="pl-inc-c">✓</span><span>A letter on the therapist's own practice letterhead, with their license number</span></div>
          <div class="pl-inc"><span class="pl-inc-c">✓</span><span>Written to your state's Fair Housing Act requirements</span></div>
          <div class="pl-inc"><span class="pl-inc-c">✓</span><span>Typically delivered within 24–48 hours</span></div>
          <div class="pl-inc"><span class="pl-inc-c">✓</span><span>Free revisions if your housing provider needs anything adjusted</span></div>
        </div>
      </div>
      <div style="background:#FBF1EB;border:1px solid rgba(24,56,64,.08);border-radius:20px;padding:clamp(28px,4vw,40px);text-align:center;">
        <div style="font-family:'Plus Jakarta Sans';font-weight:600;font-size:13px;letter-spacing:.1em;text-transform:uppercase;color:#8A9699;">Housing ESA letter</div>
        <div style="font-family:'Plus Jakarta Sans';font-weight:800;font-size:clamp(24px,4vw,30px);letter-spacing:-.02em;color:#183840;margin:14px 0 6px;line-height:1.15;">Backed by a full money-back guarantee</div>
